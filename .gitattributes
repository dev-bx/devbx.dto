# Устанавливаем LF по умолчанию для всех текстовых файлов
* text=auto eol=lf

# Явно указываем форматы файлов, которые 100% должны быть текстовыми с LF
*.php text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf

# Явно указываем бинарные файлы, чтобы Git их не трогал и не пытался менять переносы
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.zip binary
*.tar.gz binary
